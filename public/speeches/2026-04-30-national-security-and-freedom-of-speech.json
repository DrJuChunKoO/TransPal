      "id": "9dcbnv",
      "type": "speech",
      "text": "怎麼會有國家安全？",
      "speaker": "葛如鈞委員"
    },
    {
      "start": 16.96,
      "end": 18.2,
      "id": "6ctn4d",
      "type": "speech",
      "text": "沒有金融韌性，",
      "speaker": "葛如鈞委員"
    },
    {
      "start": 18.56,
      "end": 21.04,
      "id": "o1h2on",
      "type": "speech",
      "text": "怎麼會有國家安全在這裡修？",
      "speaker": "葛如鈞委員"
    },
    {
      "start": 21.04,
      "end": 24.36,
      "id": "zz6uw",

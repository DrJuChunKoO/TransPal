      "text": "國安法結果是在箝制言論",
      "speaker": "葛如鈞委員"
    },
    {
      "start": 24.36,
      "end": 27.12,
      "id": "uw6ezf",
      "type": "speech",
      "text": "自由要來處罰中間人，",
      "speaker": "葛如鈞委員"
    },
    {
      "start": 27.66,
      "end": 29.78,
      "id": "ox0brg",
      "type": "speech",
      "text": "要來數位中介法復闢。",
      "speaker": "葛如鈞委員"
    },
    {
      "start": 30.44,
      "end": 32.38,
      "id": "g8fgca",
      "type": "speech",
      "text": "這就是民進黨的國家安全嗎？",

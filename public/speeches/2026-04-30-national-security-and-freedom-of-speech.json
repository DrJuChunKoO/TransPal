      "end": 12.84,
      "id": "2hqrj",
      "type": "speech",
      "text": "怎麼會有國家安全？",
      "speaker": "葛如鈞委員"
    },
    {
      "start": 13.54,
      "end": 14.82,
      "id": "8ngo1",
      "type": "speech",
      "text": "沒有主權 AI,",
      "speaker": "葛如鈞委員"
    },
    {
